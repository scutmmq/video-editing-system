{
  "name": "video-editing-system",
  "version": "1.0.0",
  "description": "浏览器端轻量级视频剪辑与多媒体处理系统",
  "private": true,
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test tests/*.test.js",
    "build:exe:linux": "pkg . --targets node20-linux-x64 --output dist/video-editing-system-linux"
  },
  "pkg": {
    "assets": [
      "src/**/*",
      "node_modules/@ffmpeg/core/dist/umd/**/*",
      "node_modules/@ffmpeg/ffmpeg/dist/umd/**/*"
    ]
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.6.0",
    "supabase": "^2.101.0"
  }
}
